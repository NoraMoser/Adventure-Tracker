{
  "expo": {
    "name": "explorAble",
    "slug": "explorable",
    "version": "1.0.13",
    "orientation": "portrait",
    "icon": "./assets/adaptive-icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#1e3a5f"
    },
    "updates": {
      "fallbackToCacheTimeout": 0
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.noramoser.explorable",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "explorAble needs access to your location to track your activities and save your favorite spots.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "explorAble needs access to your location to track your activities in the background.",
        "NSCameraUsageDescription": "explorAble needs access to your camera to take photos of your adventure spots.",
        "NSPhotoLibraryUsageDescription": "explorAble needs access to your photo library to add photos to your saved locations.",
        "UIBackgroundModes": ["location", "fetch", "processing", "remote-notification"]
      }
    },
    "scheme": "explorable",
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F5F5F0"
      },
      "package": "com.moser.explorable",
      "versionCode": 14,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "VIBRATE",
        "RECEIVE_BOOT_COMPLETED",
        "SCHEDULE_EXACT_ALARM"
      ],
      "softwareKeyboardLayoutMode": "pan",
      "useNextNotificationsApi": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow ExplorAble to track your activities in the background for accurate route recording.",
          "isAndroidBackgroundLocationEnabled": true,
          "isBackgroundLocationEnabled": true
        }
      ],
      "expo-task-manager",
      [
        "expo-notifications",
        {
          "icon": "./assets/adaptive-icon.png",
          "color": "#2d5a3d",
          "sounds": []
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "0e548ecd-901d-40e5-a107-3a05329592e9"
      }
    }
  }
}